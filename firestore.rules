rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Preferred: set a custom claim { admin: true } on your admin account.
    function hasAdminClaim() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // Fallback: allow verified admin emails while claims are not yet configured.
    function hasAdminEmail() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          "admin@rafie.com"
        ];
    }

    // Optional UID allowlist fallback.
    function isAdmin() {
      return hasAdminClaim()
        || hasAdminEmail()
        || (isSignedIn() && request.auth.uid in [
          // "REPLACE_WITH_ADMIN_UID_1",
          // "REPLACE_WITH_ADMIN_UID_2"
        ]);
    }

    // Public portfolio read access.
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public certification read access + admin CMS write access.
    match /certifications/{certificationId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public AFK curated movie picks + admin CMS write access.
    match /moviePicks/{pickId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public AFK watchlist + admin CMS write access.
    match /movieWatchlist/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Public AFK reaction leaderboard.
    match /reactionScores/{scoreId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasOnly(['score', 'createdAt', 'source', 'initials'])
        && request.resource.data.score is int
        && request.resource.data.score >= 0
        && request.resource.data.score <= 5000
        && request.resource.data.createdAt is timestamp
        && request.resource.data.source == 'afk-reaction-time'
        && request.resource.data.initials is string
        && request.resource.data.initials.size() >= 1
        && request.resource.data.initials.size() <= 4;
      allow update, delete: if false;
    }

    // Default deny for all other collections/documents.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
